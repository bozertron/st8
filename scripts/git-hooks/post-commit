#!/usr/bin/env bash
#
# st8 post-commit hook — records commit checkpoints in st8's mutation log.
#
# When st8's HTTP server is running (default port 3847), this hook POSTs
# the commit metadata to /api/record-commit, which logs a COMMIT_CHECKPOINT
# mutation and fires the INDEX_COMPLETE hook so subscribers can react
# (regenerate manifests, schema cards, gap analysis).
#
# The hook is non-fatal: if st8 isn't running, or the POST fails, the
# commit still succeeds. This is by design — the hook is a courtesy
# notification, not a gate.
#
# INSTALLATION (one-time, per repo):
#   ln -sf ../../scripts/git-hooks/post-commit .git/hooks/post-commit
# OR:
#   bash scripts/git-hooks/install.sh
#
# To bypass (skip notification): just `git commit` as usual — the hook
# fails silently if st8 isn't reachable.

set -u

# Configuration — override via environment if needed.
ST8_HOST="${ST8_HOST:-localhost}"
ST8_PORT="${ST8_PORT:-3847}"
ST8_TIMEOUT_S="${ST8_TIMEOUT_S:-2}"

COMMIT_HASH=$(git rev-parse HEAD 2>/dev/null) || exit 0
SHORT_HASH=$(git rev-parse --short HEAD 2>/dev/null) || exit 0
SUBJECT=$(git log -1 --pretty=%s 2>/dev/null | head -c 200) || exit 0
AUTHOR=$(git log -1 --pretty='%an <%ae>' 2>/dev/null) || exit 0
TIMESTAMP=$(git log -1 --pretty=%cI 2>/dev/null) || exit 0
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || BRANCH="(detached)"
FILES_CHANGED=$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null | wc -l | tr -d ' ')

# Escape quotes/backslashes for JSON.
escape_json() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g; s/\r/\\r/g; s/\n/\\n/g'
}

PAYLOAD=$(cat <<EOF
{
  "hash": "$(escape_json "$COMMIT_HASH")",
  "shortHash": "$(escape_json "$SHORT_HASH")",
  "subject": "$(escape_json "$SUBJECT")",
  "author": "$(escape_json "$AUTHOR")",
  "timestamp": "$(escape_json "$TIMESTAMP")",
  "branch": "$(escape_json "$BRANCH")",
  "filesChanged": $FILES_CHANGED
}
EOF
)

# Fire-and-forget POST. Suppress all output so the hook is silent on success
# and silent on st8-not-running. Only one possible visible effect: stderr
# from curl itself on truly weird failures, which we also swallow.
if command -v curl >/dev/null 2>&1; then
  curl --silent --show-error --max-time "$ST8_TIMEOUT_S" \
       -X POST "http://${ST8_HOST}:${ST8_PORT}/api/record-commit" \
       -H "Content-Type: application/json" \
       -d "$PAYLOAD" \
       >/dev/null 2>&1 || true
fi

exit 0
