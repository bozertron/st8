#!/usr/bin/env bash
#
# st8 post-commit hook — records commit checkpoints in st8's mutation log.
#
# When st8's HTTP server is running (default port 3847), this hook POSTs
# the commit metadata to /api/record-commit, which logs a COMMIT_CHECKPOINT
# mutation and fires the INDEX_COMPLETE hook so subscribers can react
# (regenerate manifests, schema cards, gap analysis).
#
# The hook is non-fatal: if st8 isn't running, or the POST fails, the
# commit still succeeds. This is by design — the hook is a courtesy
# notification, not a gate.
#
# INSTALLATION (one-time, per repo):
#   ln -sf ../../scripts/git-hooks/post-commit .git/hooks/post-commit
# OR:
#   bash scripts/git-hooks/install.sh
#
# To bypass (skip notification): just `git commit` as usual — the hook
# fails silently if st8 isn't reachable.

set -u

# Configuration. Resolution order for ST8_PORT:
#   1. explicit env var (export ST8_PORT=…)
#   2. .st8/server.port written by the running server at startup
#   3. fallback default 3847
# Git invokes hooks with a minimal env, so the .st8/server.port file is the
# reliable cross-process channel — exporting ST8_PORT in a shell profile
# does NOT propagate to git hooks in most setups.
ST8_HOST="${ST8_HOST:-localhost}"
ST8_TIMEOUT_S="${ST8_TIMEOUT_S:-2}"

if [ -n "${ST8_PORT:-}" ]; then
  : # env wins
else
  REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
  PORT_FILE="${REPO_ROOT}/.st8/server.port"
  if [ -n "$REPO_ROOT" ] && [ -r "$PORT_FILE" ]; then
    # Read first line, strip whitespace, validate it's a positive integer.
    candidate=$(head -n 1 "$PORT_FILE" 2>/dev/null | tr -d ' \t\r\n')
    if [ -n "$candidate" ] && [ "$candidate" -eq "$candidate" ] 2>/dev/null && [ "$candidate" -gt 0 ] 2>/dev/null; then
      ST8_PORT="$candidate"
    fi
  fi
  ST8_PORT="${ST8_PORT:-3847}"
fi

COMMIT_HASH=$(git rev-parse HEAD 2>/dev/null) || exit 0
SHORT_HASH=$(git rev-parse --short HEAD 2>/dev/null) || exit 0
# Truncate SUBJECT to 200 bytes, then strip any incomplete trailing
# UTF-8 codepoint via `iconv -c`. Raw `head -c 200` can split a
# multi-byte codepoint and produce a malformed string that fails JSON.
# iconv may exit non-zero on the very split it's repairing — swallow
# that with `|| true` rather than letting it bail the whole hook.
SUBJECT=$( { git log -1 --pretty=%s 2>/dev/null | head -c 200 | iconv -c -f UTF-8 -t UTF-8 2>/dev/null; } || true )
AUTHOR=$(git log -1 --pretty='%an <%ae>' 2>/dev/null) || exit 0
TIMESTAMP=$(git log -1 --pretty=%cI 2>/dev/null) || exit 0
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || BRANCH="(detached)"
FILES_CHANGED=$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null | wc -l | tr -d ' ')

# Build the JSON payload. Prefer jq when available — it correctly
# escapes the full C0 control-char range (NUL, BEL, BS, FF, VT, etc.)
# AND all higher-plane characters, so commit subjects with weird bytes
# (which `git log` can emit verbatim) produce valid JSON.
#
# When jq is missing, fall back to an awk-based escaper that handles
# every U+0000..U+001F control character (per RFC 8259 §7) plus the
# two structural characters (\ and ").
if command -v jq >/dev/null 2>&1; then
  PAYLOAD=$(jq -n \
    --arg hash         "$COMMIT_HASH" \
    --arg shortHash    "$SHORT_HASH" \
    --arg subject      "$SUBJECT" \
    --arg author       "$AUTHOR" \
    --arg timestamp    "$TIMESTAMP" \
    --arg branch       "$BRANCH" \
    --argjson filesChanged "${FILES_CHANGED:-0}" \
    '{hash:$hash, shortHash:$shortHash, subject:$subject, author:$author, timestamp:$timestamp, branch:$branch, filesChanged:$filesChanged}')
else
  # Fallback: awk-based escape covering every C0 control character.
  # Emits \uXXXX for chars in U+0000..U+001F (plus \b\t\n\f\r short
  # forms where JSON specifies them) and escapes \ and ".
  escape_json() {
    printf '%s' "$1" | awk '
    BEGIN {
      for (i = 0; i < 32; i++) {
        # short forms per RFC 8259
        if (i == 8)       esc[sprintf("%c", i)] = "\\b"
        else if (i == 9)  esc[sprintf("%c", i)] = "\\t"
        else if (i == 10) esc[sprintf("%c", i)] = "\\n"
        else if (i == 12) esc[sprintf("%c", i)] = "\\f"
        else if (i == 13) esc[sprintf("%c", i)] = "\\r"
        else              esc[sprintf("%c", i)] = sprintf("\\u%04x", i)
      }
      esc["\\"] = "\\\\"
      esc["\""] = "\\\""
    }
    {
      out = ""
      n = length($0)
      for (j = 1; j <= n; j++) {
        c = substr($0, j, 1)
        if (c in esc) out = out esc[c]
        else          out = out c
      }
      printf "%s", out
      # Preserve trailing newlines between input records too.
      if (FNR < NR) out = out "\\n"
    }'
  }
  PAYLOAD=$(cat <<EOF
{
  "hash": "$(escape_json "$COMMIT_HASH")",
  "shortHash": "$(escape_json "$SHORT_HASH")",
  "subject": "$(escape_json "$SUBJECT")",
  "author": "$(escape_json "$AUTHOR")",
  "timestamp": "$(escape_json "$TIMESTAMP")",
  "branch": "$(escape_json "$BRANCH")",
  "filesChanged": ${FILES_CHANGED:-0}
}
EOF
)
fi

# Fire-and-forget POST. Suppress all output so the hook is silent on success
# and silent on st8-not-running. Only one possible visible effect: stderr
# from curl itself on truly weird failures, which we also swallow.
if command -v curl >/dev/null 2>&1; then
  curl --silent --show-error --max-time "$ST8_TIMEOUT_S" \
       -X POST "http://${ST8_HOST}:${ST8_PORT}/api/record-commit" \
       -H "Content-Type: application/json" \
       -d "$PAYLOAD" \
       >/dev/null 2>&1 || true
fi

exit 0
